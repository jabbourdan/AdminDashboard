@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Member";
}

@section Styles {
    <link href="~/css/Members.css" rel="stylesheet" />
}

<main>
    <div class="header">
        <div class="left">
            <h1>Crew</h1>
            <div></div><button id="create-user-button" class="create-user-button">Create New User</button>
        </div>
    </div>
    <div class="table" id="customers_table">
        <section class="table__header">
            <div class="input-group">
                <input type="search" placeholder="Search Data...">
            </div>
            <div class="export__file">
                <label for="export-file" class="export__file-btn" title="Export File"></label>
                <input type="checkbox" id="export-file">
                <div class="export__file-options">
                    <label>Export As &nbsp; &#10140;</label>
                    <label for="export-file" id="toPDF">PDF <img src="/Photos/Members/pdf.png" alt=""></label>
                    <label for="export-file" id="toJSON">JSON <img src="/Photos/Members/json.png" alt=""></label>
                    <label for="export-file" id="toCSV">CSV <img src="/Photos/Members/csv.png" alt=""></label>
                    <label for="export-file" id="toEXCEL">EXCEL <img src="/Photos/Members/excel.png" alt=""></label>
                </div>
            </div>
        </section>
        <section class="table__body">
            <table>
                <thead>
                    <tr>
                        <th> Id<span class="icon-arrow">&UpArrow;</span></th>
                        <th> Crew Name<span class="icon-arrow">&UpArrow;</span></th>
                        <th> Date Joined<span class="icon-arrow">&UpArrow;</span></th>
                        <th> Phone<span class="icon-arrow">&UpArrow;</span></th>
                        <th> Position<span class="icon-arrow">&UpArrow;</span></th>
                        <th> status<span class="icon-arrow">&UpArrow;</span></th>
                        <th> Edit</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td> 1 </td>
                        <td> Zinzu Chan Lee</td>
                        <td> 17 Dec, 2022 </td>
                        <td> <strong> 0509444706 </strong></td>
                        <td> Admin </td>
                        <td>
                            <p class="status delivered">Delivered</p>
                        </td>

                        <td class="edit-column"><a href="#"><i class='bx bxs-edit'></i></a></td>
                    </tr>
                    <tr>
                        <td> 2 </td>
                        <td> Jeet Saru </td>
                        <td> 27 Aug, 2023 </td>
                        <td> <strong>0556566585</strong> </td>
                        <td> Crew </td>
                        <td>
                            <p class="status cancelled">Paid</p>
                        </td>

                        <td class="edit-column"><a href="#"><i class='bx bxs-edit'></i></a></td>
                    </tr>
                    <tr>
                        <td> 3</td>
                        <td> Sonal Gharti </td>
                        <td> 14 Mar, 2023 </td>
                        <td> <strong>0569876521</strong> </td>
                        <td> Crew </td>
                        <td>
                            <p class="status shipped">Paid</p>
                        </td>
                        <td class="edit-column"><a href="#"><i class='bx bxs-edit'></i></a></td>
                    </tr>
                    
                </tbody>
            </table>
        </section>
    </div>
</main>

@section Scripts {
    <script src="~/js/Members.js"></script>
}